{
  "name": "Jornada do Casal",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "runArgs": ["--privileged"],
  "postCreateCommand": "chmod +x start.sh",
  "postStartCommand": "docker compose up -d --build && docker compose ps && sleep 3 && docker cp seed_db.py projeto-servidor-central-1:/app/seed_db.py && docker exec projeto-servidor-central-1 python3 seed_db.py",
  "forwardPorts": [8080, 8384],
  "portsAttributes": {
    "8080": {
      "label": "App",
      "onAutoForward": "openBrowser"
    },
    "8384": {
      "label": "Syncthing",
      "onAutoForward": "ignore"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
