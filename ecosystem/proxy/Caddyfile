:80 {
	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-XSS-Protection "1; mode=block"
		-Server
	}

	# API do servidor central
	handle /api/* {
		reverse_proxy servidor-central:8000
	}

	# cada app fica no seu próprio caminho
	handle_path /diario/* {
		reverse_proxy app-diario:80
	}

	handle_path /jogos/* {
		reverse_proxy app-jogos:80
	}

	handle_path /saude/* {
		reverse_proxy app-saude:80
	}

	# raiz = App Central (login + hub)
	handle {
		reverse_proxy app-central:80
	}
}
